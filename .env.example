# Google AdSense (https://www.google.com/adsense)
# 승인 후 발급받은 값을 .env 로 복사하세요. Vercel에도 동일 키를 Environment Variables로 등록합니다.
VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
VITE_ADSENSE_SLOT_TOP=0000000000
VITE_ADSENSE_SLOT_SIDEBAR=0000000000

# 저장 시 전면(동영상) 광고는 AdSense 대시보드 → 광고 → 자동 광고 → 전면 광고 에서 켜면 됩니다.
